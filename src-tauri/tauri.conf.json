{
  "$schema": "https://raw.githubusercontent.com/nicegram/tauri/v2.0.0-beta.15/core/tauri-config-schema/schema.json",
  "productName": "Scout MIB Browser",
  "version": "0.1.0",
  "identifier": "com.scout.mib-browser",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Scout MIB Browser",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

FROM docker.io/library/ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# UID/GID alignment - will be overridden at build time by sandcastle
ARG UID=1000
ARG GID=1000

RUN apt-get update && apt-get install -y \
    curl \
    git \
    jq \
    ca-certificates \
    xdg-utils \
    libssl3 \
    libayatana-appindicator3-1 \
    libnotify4 \
    libnss3 \
    libsoup3.0 \
    libwebkit2gtk-4.1-0 \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
ENV PATH="/root/.cargo/bin:${PATH}"

# Install Node.js 20 (for sandcastle runtime)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install opencode CLI
RUN curl -fsSL https://opencode.ai/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

# Create app user with matching UID/GID
RUN groupadd -g ${GID} agent || true \
    && useradd -u ${UID} -g ${GID} -m -s /bin/bash agent || true \
    && mkdir -p /home/agent/.cargo /home/agent/.local/bin /home/agent/.npm \
    && chown -R ${UID}:${GID} /home/agent

USER agent
WORKDIR /home/agent/project

ENTRYPOINT ["sleep", "infinity"]

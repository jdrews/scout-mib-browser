FROM docker.io/library/ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

ARG UID=1000
ARG GID=1000

RUN apt-get update && apt-get install -y \
    curl \
    git \
    jq \
    ca-certificates \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# Create app user with matching UID/GID (before installing tools so we can chown)
RUN groupadd -g ${GID} agent || true \
    && useradd -u ${UID} -g ${GID} -m -s /bin/bash agent || true

# Install Rust as root, then make accessible to agent
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y

# Install Node.js 20 (for sandcastle runtime)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install opencode CLI
RUN curl -fsSL https://opencode.ai/install | bash

# Make tool directories accessible to agent user
RUN chown -R ${UID}:${GID} /root/.cargo /root/.rustup \
    && if [ -d /root/.local ]; then chown -R ${UID}:${GID} /root/.local; fi \
    && chmod 755 /root

ENV PATH="/root/.cargo/bin:/root/.local/bin:${PATH}"

USER agent
WORKDIR /home/agent/project

ENTRYPOINT ["sleep", "infinity"]
